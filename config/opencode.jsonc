    // ─── 27. FreeTheAi (KEYLESS VIA DISCORD) ────────────────────────────
    // 60+ active models, free key via Discord, tool calling
    // Get key: https://freetheai.xyz (Discord server)
    "freetheai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "FreeTheAi (Free)",
      "options": {
        "baseURL": "https://freetheai.xyz/v1"
      },
