{
  "$schema": "https://opencode.ai/config.json",

  // Default agent
  "default_agent": "build",

  // Global instructions (loaded with AGENTS.md)
  "instructions": ["AGENTS.md"],

  // Default model (G4F local keyless aggregator - 91+ models, no API key)
  "model": "g4f/gpt-4o-mini",

  // Lightweight tasks use a cheaper model
  "small_model": "g4f/gpt-4o-mini",

  // === SKILL PERMISSIONS ===
  // All skills in this config are safe to use
  "permission": {
    "skill": {
      "*": "allow",
      "experimental-*": "ask"
    }
  },

  // === MODEL FAILOVER CONFIG ===
  // When a model fails, use /switch-model or @model-router to auto-failover
  // through the fallback chain of 28 free models

  // === FREE AI PROVIDERS (2026 - ~26 providers, 100+ models) ===
  // API keys: add via /connect command in TUI (except keyless providers)
  // Keyless providers work immediately without any key

  "provider": {

    // ═══════════════════════════════════════════════════════════════════════
    //  CATEGORY 1: KEYLESS (NO API KEY REQUIRED)
    // ═══════════════════════════════════════════════════════════════════════

    // ─── 1. Pollinations.ai (KEYLESS - VERIFIED WORKS) ─────────────────
    // No API key required! 1 concurrent request per IP. Tested ✅
    "pollinations": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Pollinations AI (Keyless)",
      "options": {
        "baseURL": "https://text.pollinations.ai/openai"
      },
      "models": {
        "openai": { "name": "GPT-OSS 20B (Tool-capable)" }
      }
    },

    // ─── 2. ApiAirforce (REQUIRES AUTH - NOT KEYLESS) ────────────────
    // Previously keyless, now requires API key. :free models need auth.
    // Falls back to other keyless providers.
    "apiairforce": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "ApiAirforce (Keyless)",
      "options": {
        "baseURL": "https://api.airforce/v1"
      },
      "models": {
        "openai": { "name": "OpenAI-compatible (Keyless)" },
        "grok-4.1-mini": { "name": "Grok 4.1 Mini" },
        "step-3.5-flash": { "name": "Step 3.5 Flash" },
        "gemma3-270m": { "name": "Gemma 3 270M" },
        "moirai-agent": { "name": "Moirai Agent" },
        "translategemma-27b": { "name": "TranslateGemma 27B" }
      }
    },

    // ─── 3. Kilo Gateway (KEYLESS - VERIFIED WORKS ✅) ─────────────────
    // No API key required for :free models. 200 req/hr/IP. Tested ✅
    "kilo": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kilo Gateway (Keyless)",
      "options": {
        "baseURL": "https://api.kilo.ai/api/gateway"
      },
      "models": {
        "kilo-auto/free": { "name": "Kilo Auto Free (auto-routed)" },
        "tencent/hy3:free": { "name": "Tencent Hunyuan 3" },
        "stepfun/step-3.7-flash:free": { "name": "Step 3.7 Flash" },
        "nvidia/nemotron-3-ultra-550b-a55b:free": { "name": "Nemotron 3 Ultra 550B" },
        "nvidia/nemotron-3-super-120b-a12b:free": { "name": "Nemotron 3 Super 120B" },
        "poolside/laguna-m.1:free": { "name": "Poolside Laguna M.1" },
        "cohere/north-mini-code:free": { "name": "Cohere North Mini Code" },
        "openrouter/free": { "name": "OpenRouter Auto-Free" }
      }
    },

    // ─── 5. OVHcloud AI Endpoints (KEYLESS - VERIFIED WORKS) ──────────
    // Without key: 2 req/min/IP | With key: ~400 RPM. Tested ✅
    // Returns 429 on rate limit, then auto-fallbacks
    "ovhcloud": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OVHcloud AI (Keyless)",
      "options": {
        "baseURL": "https://oai.endpoints.kepler.ai.cloud.ovh.net/v1"
      },
      "models": {
        "Mistral-7B-Instruct-v0.3": { "name": "Mistral 7B v0.3" },
        "Meta-Llama-3_3-70B-Instruct": { "name": "Llama 3.3 70B" },
        "Qwen3.6-27B": { "name": "Qwen 3.6 27B (1M ctx)" },
        "Qwen3-Coder-30B-A3B-Instruct": { "name": "Qwen 3 Coder 30B" },
        "Mistral-Small-3.2-24B-Instruct": { "name": "Mistral Small 3.2 24B" },
        "Llama-3.1-8B-Instruct": { "name": "Llama 3.1 8B" },
        "Mistral-Nemo-Instruct-2407": { "name": "Mistral Nemo" },
        "Qwen2.5-VL-72B-Instruct": { "name": "Qwen 2.5 VL 72B (Vision)" }
      }
    },

    // ─── 6. smanx free-api (KEYLESS - UPSTREAM UNSTABLE) ────────────
    // Public keyless endpoint using shared API key. Re-emerged 2026.
    // Note: upstream sometimes 502/503, acts as last-resort fallback
    "smanxfree": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "smanx Free API (Keyless)",
      "options": {
        "baseURL": "https://openai.good.hidns.vip/v1"
      },
      "models": {
        "gpt-5.2": { "name": "GPT-5.2 (unstable)" },
        "gpt-4o": { "name": "GPT-4o (unstable)" }
      }
    },

    // ═══════════════════════════════════════════════════════════════════════
    //  CATEGORY 2: FREE TIER (API KEY REQUIRED, NO CREDIT CARD)
    // ═══════════════════════════════════════════════════════════════════════

    // ─── 7. Groq ────────────────────────────────────────────────────────
    // Free: 30 RPM, 1,000 RPD | Ultra-fast LPU inference
    // Sign up: https://console.groq.com
    "groq": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Groq (Free)",
      "options": {
        "baseURL": "https://api.groq.com/openai/v1"
      },
      "models": {
        "llama-3.3-70b-versatile": { "name": "Llama 3.3 70B" },
        "llama-4-scout-17b-16e-instruct": { "name": "Llama 4 Scout 17B" },
        "qwen-qwen3-32b": { "name": "Qwen3 32B" },
        "gpt-oss-120b": { "name": "GPT-OSS 120B" },
        "mistral-saba-24b": { "name": "Mistral Saba 24B" },
        "llama-3.1-8b-instant": { "name": "Llama 3.1 8B Instant" }
      }
    },

    // ─── 8. Cerebras ────────────────────────────────────────────────────
    // Free: 30 RPM, 1M tokens/day | ~2,600 tok/s inference
    // Sign up: https://inference.cerebras.ai
    "cerebras": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Cerebras (Free)",
      "options": {
        "baseURL": "https://api.cerebras.ai/v1"
      },
      "models": {
        "gpt-oss-120b": { "name": "GPT-OSS 120B" },
        "gpt-oss-20b": { "name": "GPT-OSS 20B" },
        "qwen3-235b": { "name": "Qwen3 235B" },
        "llama-3.1-70b": { "name": "Llama 3.1 70B" },
        "zai-glm-4.7": { "name": "Z.AI GLM 4.7" }
      }
    },

    // ─── 9. Mistral AI ─────────────────────────────────────────────────
    // Free Experiment tier: 1B tokens/month, ~2 RPM
    // Sign up: https://console.mistral.ai
    "mistral": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Mistral AI (Free)",
      "options": {
        "baseURL": "https://api.mistral.ai/v1"
      },
      "models": {
        "mistral-large-3": { "name": "Mistral Large 3 (128B)" },
        "mistral-medium-3.5": { "name": "Mistral Medium 3.5 (128B)" },
        "mistral-small-3.1": { "name": "Mistral Small 3.1" },
        "mistral-small-4": { "name": "Mistral Small 4" },
        "codestral": { "name": "Codestral" },
        "open-mistral-nemo": { "name": "Open Mistral Nemo (12B)" },
        "pixtral-large": { "name": "Pixtral Large (Vision)" }
      }
    },

    // ─── 10. NVIDIA NIM ────────────────────────────────────────────────
    // Free: build credits, ~40 RPM, 100+ models
    // Sign up: https://build.nvidia.com
    "nvidia": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NVIDIA NIM (Free)",
      "options": {
        "baseURL": "https://integrate.api.nvidia.com/v1"
      },
      "models": {
        "deepseek-ai/deepseek-r1": { "name": "DeepSeek R1" },
        "nvidia/nemotron-3-super-120b-a12b": { "name": "Nemotron 3 Super 120B" },
        "nvidia/nemotron-3-nano-30b-a3b": { "name": "Nemotron 3 Nano 30B" },
        "nvidia/llama-3.1-nemotron-ultra-253b-v1": { "name": "Nemotron Ultra 253B" },
        "meta/llama-3.3-70b-instruct": { "name": "Llama 3.3 70B" },
        "meta/llama-3.1-405b-instruct": { "name": "Llama 3.1 405B" },
        "qwen/qwen2.5-72b-instruct": { "name": "Qwen 2.5 72B" },
        "microsoft/phi-4": { "name": "Phi-4" },
        "mistralai/mistral-large-2-instruct": { "name": "Mistral Large 2" },
        "google/gemma-4-31b": { "name": "Gemma 4 31B" },
        "minimax/minimax-m2.7": { "name": "MiniMax M2.7" },
        "kimi/k2.6": { "name": "Kimi K2.6" }
      }
    },

    // ─── 11. OpenRouter (Free Models) ───────────────────────────────────
    // ~22 free models via :free suffix | 200 RPD per model
    // Sign up: https://openrouter.ai
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter (Free)",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1"
      },
      "models": {
        "qwen/qwen3-coder:free": { "name": "Qwen3 Coder (Free)" },
        "nvidia/nemotron-3-ultra-550b-a55b:free": { "name": "Nemotron 3 Ultra 550B (Free)" },
        "nvidia/nemotron-3-super-120b-a12b:free": { "name": "Nemotron 3 Super 120B (Free)" },
        "openai/gpt-oss-120b:free": { "name": "GPT-OSS 120B (Free)" },
        "openai/gpt-oss-20b:free": { "name": "GPT-OSS 20B (Free)" },
        "meta-llama/llama-3.3-70b-instruct:free": { "name": "Llama 3.3 70B (Free)" },
        "nousresearch/hermes-3-llama-3.1-405b:free": { "name": "Hermes 3 405B (Free)" },
        "google/gemma-4-31b-it:free": { "name": "Gemma 4 31B (Free)" },
        "poolside/laguna-m.1:free": { "name": "Poolside Laguna M.1 (Free)" },
        "qwen/qwen3-next-80b-a3b-instruct:free": { "name": "Qwen3 Next 80B (Free)" },
        "tencent/hunyuan3:free": { "name": "Hunyuan 3 (Free)" },
        "minimax/minimax-m2.5:free": { "name": "MiniMax M2.5 (Free)" }
      }
    },

    // ─── 12. Cloudflare Workers AI ─────────────────────────────────────
    // Free: 10,000 neurons/day | 50+ models
    // Sign up: https://dash.cloudflare.com
    // baseURL needs YOUR account_id: /client/v4/accounts/{account_id}/ai/v1
    "cloudflare": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Cloudflare Workers AI (Free)",
      "options": {
        "baseURL": "https://api.cloudflare.com/client/v4/accounts/YOUR_ACCOUNT_ID/ai/v1"
      },
      "models": {
        "@cf/moonshotai/kimi-k2.6": { "name": "Kimi K2.6" },
        "@cf/moonshotai/kimi-k2.7-code": { "name": "Kimi K2.7 Code" },
        "@cf/meta/llama-3.3-70b-instruct-fp8-fast": { "name": "Llama 3.3 70B" },
        "@cf/meta/llama-4-scout-17b-16e-instruct": { "name": "Llama 4 Scout 17B" },
        "@cf/openai/gpt-oss-120b": { "name": "GPT-OSS 120B" },
        "@cf/openai/gpt-oss-20b": { "name": "GPT-OSS 20B" },
        "@cf/qwen/qwen2.5-coder-32b": { "name": "Qwen 2.5 Coder 32B" },
        "@cf/google/gemma-4-26b-a4b-it": { "name": "Gemma 4 26B" },
        "@cf/deepseek-ai/deepseek-r1-distill-qwen-32b": { "name": "DeepSeek R1 Distill 32B" },
        "@cf/zhipuai/glm-4.7-flash": { "name": "GLM 4.7 Flash" },
        "@cf/mistralai/mistral-small-3.1-24b-instruct": { "name": "Mistral Small 3.1 24B" }
      }
    },

    // ─── 13. Together AI ────────────────────────────────────────────────
    // Free: 68 zero-cost models + $25 credits
    // Sign up: https://api.together.ai
    "togetherai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Together AI (Free)",
      "options": {
        "baseURL": "https://api.together.ai/v1"
      },
      "models": {
        "meta-llama/Llama-3.3-70B-Instruct-Turbo": { "name": "Llama 3.3 70B Turbo" },
        "qwen/Qwen2.5-Coder-32B-Instruct": { "name": "Qwen 2.5 Coder 32B" },
        "google/gemma-4-31B-it": { "name": "Gemma 4 31B" },
        "mistralai/Mistral-Small-3.1": { "name": "Mistral Small 3.1" },
        "openai/gpt-oss-20b": { "name": "GPT-OSS 20B" }
      }
    },

    // ─── 14. SambaNova ──────────────────────────────────────────────────
    // Free: 20 RPM, 200K tokens/day | $5 trial credits
    // Sign up: https://cloud.sambanova.ai
    "sambanova": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "SambaNova (Free)",
      "options": {
        "baseURL": "https://api.sambanova.ai/v1"
      },
      "models": {
        "DeepSeek-V3.1": { "name": "DeepSeek V3.1" },
        "DeepSeek-V3.2-Preview": { "name": "DeepSeek V3.2 Preview" },
